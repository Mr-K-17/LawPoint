# Example .env for LAW POINT backend
# Replace values with your own.

# MongoDB connection string. For local DB use: mongodb://localhost:27017/lawpoint
MONGODB_URI=mongodb://localhost:27017/lawpoint

# JWT secret for signing tokens — use a long random string
JWT_SECRET=supersecretkey12345

# Server port (optional, defaults to 5000)
PORT=5000

# CORS origin for the frontend (optional)
CORS_ORIGIN=http://localhost:3000

# Optional AI keys for LawBot (OpenAI or Gemini)
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_PROVIDER=openai
